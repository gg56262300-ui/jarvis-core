NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DB_PATH=./data/jarvis.sqlite

OPENAI_API_KEY=
# Kui PM2 ei tohiks võtit keskkonnas hoida: üks rida võtit, OPENAI_API_KEY jäta tühjaks või ära sea
# OPENAI_API_KEY_FILE=./data/openai-api-key.txt
# Valikuline — mitme org / projekti võti; vale väärtus → 401 (eemalda või paranda)
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=
# OPENAI_BASE_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Tühi localhost: kalender → /api/calendar/google/callback; Gmail/kontaktid → /oauth2/google
GOOGLE_REDIRECT_URI=
GOOGLE_PROJECT_ID=
GOOGLE_WORKSPACE_USER=

VOICE_PROVIDER_API_KEY=
CRM_PROVIDER_API_KEY=
SENTRY_DSN=

# Meta WhatsApp Cloud API (veebihook: GET/POST /api/whatsapp/webhook)
# WHATSAPP_CLOUD_VERIFY_TOKEN=
# WHATSAPP_CLOUD_APP_SECRET=
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# WHATSAPP_CLOUD_GRAPH_VERSION=v21.0
