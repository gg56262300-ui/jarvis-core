NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DB_PATH=./data/jarvis.sqlite

OPENAI_API_KEY=
# Valikuline — Robert + Telegram kasutavad sama chat.completions voogu; vaikimisi gpt-4o-mini
# JARVIS_CHAT_COMPLETION_MODEL=gpt-4o-mini
# DeepSeek (OpenAI-ühilduv): nt OPENAI_BASE_URL=https://api.deepseek.com + OPENAI_API_KEY=<deepseek> + JARVIS_CHAT_COMPLETION_MODEL=deepseek-chat
# OPENAI_BASE_URL=
# Kui PM2 ei tohiks võtit keskkonnas hoida: üks rida võtit, OPENAI_API_KEY jäta tühjaks või ära sea
# OPENAI_API_KEY_FILE=./data/openai-api-key.txt
# Valikuline — mitme org / projekti võti; vale väärtus → 401 (eemalda või paranda)
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=
# OPENAI_BASE_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Soovitus: kasuta eraldi redirect-e (avalik HTTPS toodangus)
GOOGLE_GMAIL_REDIRECT_URI=
GOOGLE_CONTACTS_REDIRECT_URI=
GOOGLE_CALENDAR_REDIRECT_URI=
# Legacy fallback (kui kasutad ühte väärtust): localhost → teenuse vaikimisi callback
GOOGLE_REDIRECT_URI=
GOOGLE_PROJECT_ID=
GOOGLE_WORKSPACE_USER=

VOICE_PROVIDER_API_KEY=
CRM_PROVIDER_API_KEY=
SENTRY_DSN=

# Meta WhatsApp Cloud API (veebihook: GET/POST /api/whatsapp/webhook)
# WHATSAPP_CLOUD_VERIFY_TOKEN=
# WHATSAPP_CLOUD_APP_SECRET=
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# WHATSAPP_CLOUD_GRAPH_VERSION=v21.0

# Telegram (väljaminev teade + kahesuunaline tekst webhookiga)
# Ilma avaliku HTTPS-ita (Mac): true → getUpdates + kohalik forward (käivitamisel deleteWebhook)
# TELEGRAM_USE_POLLING=true
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Soovituslik: setWebhook secret_token — päring peab kandma päist X-Telegram-Bot-Api-Secret-Token
# TELEGRAM_WEBHOOK_SECRET=
# Pärast boti vastust pinChatMessage (üleval nähtav); välja: false
# TELEGRAM_PIN_BOT_REPLY=true
# Roberti vastus ka häälsõnumina (OpenAI TTS → sendVoice); nõuab OPENAI_API_KEY
# TELEGRAM_VOICE_REPLY=true
# TELEGRAM_TTS_MODEL=tts-1
# TELEGRAM_TTS_VOICE=nova
# Valikuline koodisõna sissetulekul + allkiri väljaminekul (vt /jarvis juhend)
# TELEGRAM_INBOUND_PREFIX_REQUIRED=true
# TELEGRAM_INBOUND_PREFIX=Jarvis
# TELEGRAM_REPLY_SIGNATURE=▸ Jarvis
# Vaikimisi Europe/Tallinn (kalendri «täna» ankur, kui sõnum tuleb Telegramist)
# TELEGRAM_DEFAULT_TIMEZONE=Europe/Tallinn
# Roberti süsteemviiba keel Telegramist (nt ru, et-EE)
# TELEGRAM_DEFAULT_LOCALE=ru
# Kohalik webhooki test (POST /api/integrations/telegram/webhook): npm run telegram:webhook-smoke
# TELEGRAM_WEBHOOK_SMOKE_URL=http://127.0.0.1:3000
# TELEGRAM_WEBHOOK_SMOKE_TEXT=/ping
# Olek (GET, saladusi ei tagasta): /api/integrations/telegram/status
# Avalik HTTPS (tunnel/VPS), ilma lõpupõikketa — `npm run telegram:set-webhook` koostab webhooki aadressi
# JARVIS_WEBHOOK_PUBLIC_BASE=https://example.ngrok-free.app
# Lisa ?webhook=1, et näha Telegrami getWebhookInfo (URL, ootel uuendused) — token jääb serverisse
